{
  "name": "quizparts",
  "private": true,
  "repository": {
    "type": "git",
    "url": "https://github.com/quizparts/quizparts.git"
  },
  "homepage": "https://github.com/quizparts/quizparts#readme",
  "bugs": {
    "url": "https://github.com/quizparts/quizparts/issues"
  },
  "workspaces": [
    "packages/*",
    "apps/*",
    "examples/*"
  ],
  "scripts": {
    "dev": "turbo run dev --parallel",
    "storybook": "turbo run dev --filter=@quizparts/storybook",
    "build": "turbo run build",
    "lint": "turbo run lint",
    "typecheck": "turbo run typecheck",
    "test": "turbo run test",
    "test:e2e": "playwright test",
    "clean": "turbo run clean",
    "release": "changeset publish"
  },
  "devDependencies": {
    "@changesets/cli": "^2.27.10",
    "@playwright/test": "^1.49.0",
    "@types/node": "^22.10.0",
    "@typescript-eslint/eslint-plugin": "^8.15.0",
    "@typescript-eslint/parser": "^8.15.0",
    "eslint": "^8.57.0",
    "eslint-config-prettier": "^9.1.0",
    "prettier": "^3.3.3",
    "turbo": "^2.3.0",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  },
  "packageManager": "yarn@1.22.22",
  "engines": {
    "node": ">=18"
  }
}
