{
  "name": "@quizparts/theme",
  "version": "0.0.1",
  "description": "Theme tokens and default CSS for QuizParts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quizparts/quizparts.git"
  },
  "homepage": "https://github.com/quizparts/quizparts#readme",
  "bugs": {
    "url": "https://github.com/quizparts/quizparts/issues"
  },
  "keywords": ["quiz", "theme", "css", "design-tokens", "learning"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./play.css": "./dist/play.css"
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc && cp src/play.css dist/play.css",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
