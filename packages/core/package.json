{
  "name": "@quizparts/core",
  "version": "0.0.1",
  "description": "Headless quiz engine for QuizParts (session, submit, progress)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/quizparts/quizparts.git"
  },
  "homepage": "https://github.com/quizparts/quizparts#readme",
  "bugs": {
    "url": "https://github.com/quizparts/quizparts/issues"
  },
  "keywords": ["quiz", "headless", "engine", "learning", "typescript"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@quizparts/schema": "0.0.1"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
