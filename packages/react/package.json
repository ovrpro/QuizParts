{
  "name": "@quizparts/react",
  "version": "0.0.2",
  "description": "React UI for QuizParts (web) — start here. Provider, components, and hooks; includes engine and schema.",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ovrpro/QuizParts.git"
  },
  "homepage": "https://github.com/ovrpro/QuizParts#readme",
  "bugs": {
    "url": "https://github.com/ovrpro/QuizParts/issues"
  },
  "keywords": [
    "quiz",
    "react",
    "components",
    "learning",
    "headless"
  ],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist"
  ],
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts,.tsx",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@quizparts/core": "0.0.1",
    "@quizparts/schema": "0.0.1",
    "@quizparts/theme": "0.0.2"
  },
  "peerDependencies": {
    "react": ">=18"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/jest-dom": "^6.6.3",
    "@testing-library/react": "^16.0.1",
    "@testing-library/user-event": "^14.5.2",
    "@types/react": "^18.3.12",
    "happy-dom": "^15.11.7",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
