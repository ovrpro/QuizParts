{
  "name": "@quizparts/schema",
  "version": "0.0.1",
  "description": "Quiz and question types, validation, and parsing for QuizParts",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/ovrpro/QuizParts.git"
  },
  "homepage": "https://github.com/ovrpro/QuizParts#readme",
  "bugs": {
    "url": "https://github.com/ovrpro/QuizParts/issues"
  },
  "keywords": ["quiz", "schema", "validation", "typescript", "learning"],
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": ["dist"],
  "publishConfig": { "access": "public" },
  "scripts": {
    "build": "tsc",
    "lint": "eslint src --ext .ts",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "clean": "rm -rf dist"
  },
  "devDependencies": {
    "typescript": "^5.6.3",
    "vitest": "^2.1.4"
  }
}
